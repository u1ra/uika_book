# Port exposed to the host machine
FRONTEND_PORT=7234

# Backend runtime settings
APP_NAME=uika_book API
APP_VERSION=0.1.0
DEBUG=false
DATA_DIR=/app/data
UPLOAD_DIR=/app/uploads
DATABASE_URL=
# 生产部署必须修改：留空时后端会回退到公开默认值并打印告警。
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DEFAULT_ADMIN_USERNAME=admin
# 生产部署必须修改：默认 admin123 仅适合首次本地体验。
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_TXT_ENCODING=utf-8
# 应用层上传大小上限（MB）。书籍上传应与 nginx client_max_body_size（100m）对齐。
MAX_UPLOAD_SIZE_MB=100
MAX_COVER_SIZE_MB=10
